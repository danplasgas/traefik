[Unit]
Description=Traefik Admin UI
After=network-online.target traefik-admin-helper.service
Wants=network-online.target

[Service]
Type=simple
User=dan
Group=dan
WorkingDirectory=/home/dan/work/tmweb/infra/traefik
ExecStart=/usr/bin/python3 /home/dan/work/tmweb/infra/traefik/admin-ui/serve.py
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=false
ReadOnlyPaths=/home/dan/work/tmweb/infra/traefik/admin-ui

[Install]
WantedBy=multi-user.target
